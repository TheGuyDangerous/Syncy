{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Syncy",
  "version": "0.1.0",
  "identifier": "dev.syncy.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Syncy",
        "width": 1040,
        "height": 720,
        "minWidth": 760,
        "minHeight": 540,
        "center": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "GuyDangerous Studios",
    "copyright": "Copyright © 2026 GuyDangerous Studios",
    "category": "Utility",
    "shortDescription": "Local-first P2P folder sync",
    "longDescription": "Syncy is a fast, secure, local-first peer-to-peer folder synchronization engine.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
